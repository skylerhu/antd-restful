{
  "verbose": true,
  "testEnvironment": "jest-environment-jsdom",
  "setupFilesAfterEnv": [
    "<rootDir>/setupTests.js"
  ],
  "moduleFileExtensions": [
    "js",
    "jsx",
    "ts",
    "tsx",
    "json"
  ],
  "modulePaths": [
    "<rootDir>/src"
  ],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "testMatch": [
    "**/tests/**/*.{js,jsx,ts}"
  ],
  "collectCoverage": true,
  "coverageDirectory": "./.coverage",
  "collectCoverageFrom": [
    "src/**/*.{js,jsx,ts}",
    "!**/node_modules/**"
  ]
}
