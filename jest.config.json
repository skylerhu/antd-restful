{
  "verbose": true,
  "testEnvironment": "jest-environment-jsdom",
  "transform": {
    "^.+\\.(js|jsx)$": [
      "babel-jest", {
        "presets": ["@babel/preset-env", "@babel/preset-react"]
      }
    ]
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(query-string|decode-uri-component|filter-obj|split-on-first|string-format|object-path|js-enumerate|dequal|copy-to-clipboard|brace-expansion)/)"
  ],
  "setupFilesAfterEnv": [
    "<rootDir>/setupTests.js"
  ],
  "moduleFileExtensions": [
    "js",
    "jsx",
    "ts",
    "tsx",
    "json"
  ],
  "modulePaths": [
    "<rootDir>/src"
  ],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "testMatch": [
    "**/tests/**/*.{js,jsx,ts}"
  ],
  "collectCoverage": true,
  "coverageDirectory": "./.coverage",
  "collectCoverageFrom": [
    "src/**/*.{js,jsx,ts}",
    "!**/node_modules/**"
  ]
}
